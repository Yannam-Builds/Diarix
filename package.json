{
  "name": "diarix",
  "version": "0.1.0-alpha.1",
  "private": true,
  "workspaces": [
    "app",
    "tauri"
  ],
  "scripts": {
    "dev": "bun run setup:dev && cd tauri && bun run tauri dev",
    "dev:server": "uvicorn backend.main:app --reload --port 17494",
    "setup:dev": "bun run scripts/setup-dev-sidecar.js",
    "build": "./scripts/build-server.sh && cd tauri && bun run tauri build",
    "build:release": "./scripts/prepare-release.sh",
    "generate:api": "./scripts/generate-api.sh",
    "generate:keys": "cd tauri && bun tauri signer generate -w ~/.tauri/diarix.key",
    "build:server": "./scripts/build-server.sh",
    "lint": "biome lint .",
    "typecheck": "tsc -p app/tsconfig.json --noEmit",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "verify:alpha": "node scripts/verify-alpha.mjs",
    "ci": "node scripts/verify-alpha.mjs && tsc -p app/tsconfig.json --noEmit && cd app && vite build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@types/node": "^20.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.8",
  "dependencies": {
    "loaders.css": "^0.1.2",
    "react-loaders": "^3.0.1"
  }
}
